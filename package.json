    "@playwright/test": "1.61.1",
    "@typescript/native": "npm:typescript@7.0.2",
    "@types/node": "26.1.0",
    "convex": "1.42.1",
    "eslint": "10.0.1",
    "globals": "17.7.0",
    "typescript": "npm:@typescript/typescript6@6.0.2",
    "typescript-eslint": "8.62.1",
    "vitest": "4.1.9"
