{
  "name": "trail-planner-workspace",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@11.10.0",
  "scripts": {
    "dev": "convex dev --start 'pnpm --filter @trail-planner/web dev'",
